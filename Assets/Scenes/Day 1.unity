  m_Script: {fileID: 11500000, guid: 97bf22525ebb065418cf67a1779adf55, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::NPCInteractable
  interactionPrompt: Interact
  npcName: Lord T. Time
  dialogueText: "Lord T. Time: \u201CYou know, the poor do have a rather unfortunate
    habit of meeting such dreadful ends. How terribly sad. Do you happen to know
    whether they\u2019ve removed the body yet? I should hate to return to my quarters
    only to find plebeian blood all over my shoes.\u201D\r\nResponse: Did you see
    anything?\r\nLord T. Time: Do you honestly imagine I have the time to converse
    with someone of your standing?"
  displayDuration: 14
  onInteract:
    m_PersistentCalls:
      m_Calls: []
